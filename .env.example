# Supabase Configuration
# Get these values from https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api

# The URL of your Supabase project
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# The anonymous (public) key for your Supabase project
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (Optional) Supabase service role key (for backend only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Application Configuration
VITE_APP_NAME=Babu Takeaway
VITE_APP_URL=http://localhost:5173
